{
    "name":  "orca-universal-proxy",
    "version":  "2.1.0",
    "description":  "Universal proxy for Codex CLI, Claude Desktop, and all major Chinese LLM APIs",
    "main":  "main.js",
    "scripts":  {
                    "dev":  "ts-node src/index.ts",
                    "build:ui":  "cd frontend \u0026\u0026 npm install \u0026\u0026 npm run build",
                    "build":  "npm run build:ui \u0026\u0026 tsc \u0026\u0026 esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js --format=cjs",
                    "start":  "electron .",
                    "package":  "npm run build:ui \u0026\u0026 tsc \u0026\u0026 esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js --format=cjs \u0026\u0026 electron-builder --win"
                },
    "build":  {
                  "appId":  "com.orca.proxy",
                  "productName":  "Orca Proxy",
                  "forceCodeSigning":  false,
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "main.js",
                                "dist/bundle.js",
                                "public/**/*",
                                "assets/**/*",
                                "skills/**/*",
                                "package.json"
                            ],
                  "win":  {
                              "signAndEditExecutable": false,
                              "target":  [
                                             {
                                                 "target":  "nsis",
                                                 "arch":  [
                                                              "x64"
                                                          ]
                                             }
                                         ]
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "createDesktopShortcut":  true,
                               "createStartMenuShortcut":  true,
                               "shortcutName":  "Orca Proxy",
                               "runAfterFinish":  true
                           }
              },
    "dependencies":  {
                         "dotenv":  "^16.4.0",
                         "express":  "^4.21.0",
                         "express-rate-limit":  "^7.5.0"
                     },
    "devDependencies":  {
                            "@types/express":  "^4.17.21",
                            "@types/node":  "^22.0.0",
                            "electron":  "^35.7.5",
                            "electron-builder":  "^26.0.0",
                            "esbuild":  "^0.28.0",
                            "ts-node":  "^10.9.0",
                            "typescript":  "^5.6.0"
                        },
    "license":  "MIT"
}
